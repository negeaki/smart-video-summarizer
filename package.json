{
  "name": "obsidian-smart-video-summarizer",
  "version": "1.0.0",
  "description": "Generate structured summaries from YouTube/Bilibili videos with timestamp linking",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint ."
  },
  "keywords": ["obsidian", "plugin", "video", "summary", "timestamp"],
  "license": "BSD-0-Clause",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.5.0",
    "@eslint/js": "9.30.1",
    "@types/node": "^16.11.6",
    "esbuild": "0.25.5",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "14.0.0",
    "jiti": "2.6.1",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.35.1"
  },
  "dependencies": {
    "youtube-transcript": "^1.3.0"
  }
}